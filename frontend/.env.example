# ============================================
# QR TRACKING SYSTEM - Environment Variables
# ============================================
# Copy this file as .env: cp .env.example .env
# फिर अपनी values भरो

# ---------- Server ----------
NODE_ENV=development
PORT=5000

# ---------- MongoDB ----------
# Create a free cluster at MongoDB Atlas: https://cloud.mongodb.com
# Paste your connection string here
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/qr-tracking?retryWrites=true&w=majority

# ---------- JWT Secret ----------
# Use any random strong string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_minimum_32_chars
JWT_EXPIRE=30d

# ---------- Frontend URL ----------
FRONTEND_URL=http://localhost:3000

# ---------- Email (Notifications) ----------
# Create a Gmail App Password:
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@qrtracker.com
FROM_NAME=QR Tracker

# ---------- Firebase (Push Notifications) ----------
# Firebase Console → Project Settings → Service Account → Generate Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ---------- SMS (Twilio) ----------
# Create a free account at Twilio.com
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# ---------- Google Maps ----------
# Google Cloud Console → APIs → Enable Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ---------- Razorpay (Payments) ----------
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
